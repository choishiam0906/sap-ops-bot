# 윈도우 크기
WINDOW_WIDTH=1320
WINDOW_HEIGHT=860

# Codex (OpenAI)
CODEX_OAUTH_VERIFICATION_URL=https://chat.openai.com/auth/device
CODEX_OAUTH_TOKEN_URL=https://api.openai.com/oauth/token
CODEX_API_BASE_URL=https://api.openai.com/v1

# Copilot (GitHub)
COPILOT_OAUTH_VERIFICATION_URL=https://github.com/login/device
COPILOT_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
COPILOT_API_BASE_URL=https://api.githubcopilot.com

# Backend
SAP_OPS_BACKEND_API_BASE_URL=http://127.0.0.1:8000/api/v1

# CBO
CBO_MAX_FILE_SIZE_BYTES=500000
CBO_SUPPORTED_EXTENSIONS=.txt,.md,.abap,.cbo
