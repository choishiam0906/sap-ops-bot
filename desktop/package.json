{
  "name": "sap-assistant-desktop-platform",
  "version": "2.5.0",
  "private": true,
  "description": "SAP Assistant Desktop Platform desktop runtime (user OAuth: Codex + Copilot)",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json && vite build --config vite.renderer.config.ts",
    "build:main": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "dev": "tsx src/main/index.ts",
    "lint": "eslint src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:nsis": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.5",
    "keytar": "^7.9.0",
    "lucide-react": "^0.577.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.4.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "happy-dom": "^20.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.7",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.sapassistantdesktop.platform",
    "productName": "SAP Assistant Desktop Platform",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SAP-Assistant-Desktop-Platform-${version}-Setup.exe",
      "shortcutName": "SAP Assistant Desktop Platform"
    },
    "portable": {
      "artifactName": "SAP-Assistant-Desktop-Platform-${version}-Portable.exe"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/keytar/**"
    ]
  }
}
